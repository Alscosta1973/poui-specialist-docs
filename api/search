droes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#quick-reference--13-known-quirks","content":"PoTableDetail"},"1899":{"id":"/docs/padroes/po-ui-quirks-75","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#quick-reference--13-known-quirks","content":"TS2353: `width` not in type"},"1900":{"id":"/docs/padroes/po-ui-quirks-76","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#quick-reference--13-known-quirks","content":"Remove `width` from detail columns — only `property`, `label`, `type`, `format` valid"},"1901":{"id":"/docs/padroes/po-ui-quirks-77","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#quick-reference--13-known-quirks","content":"12"},"1902":{"id":"/docs/padroes/po-ui-quirks-78","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#quick-reference--13-known-quirks","content":"po-table"},"1903":{"id":"/docs/padroes/po-ui-quirks-79","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#quick-reference--13-known-quirks","content":"**Invisible on first load in OnPush component**"},"1904":{"id":"/docs/padroes/po-ui-quirks-80","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#quick-reference--13-known-quirks","content":"Always set `[p-height]` — without it, opacity is set via async `setTimeout` and OnPush never re-renders"},"1905":{"id":"/docs/padroes/po-ui-quirks-81","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#quick-reference--13-known-quirks","content":"13"},"1906":{"id":"/docs/padroes/po-ui-quirks-82","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#quick-reference--13-known-quirks","content":"po-dynamic-form"},"1907":{"id":"/docs/padroes/po-ui-quirks-83","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#quick-reference--13-known-quirks","content":"**`(p-value-change)` silently does nothing**"},"1908":{"id":"/docs/padroes/po-ui-quirks-84","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#quick-reference--13-known-quirks","content":"Output doesn't exist — use `(p-form)=\"fn($event)\"` + subscribe `form.valueChanges`"},"1909":{"id":"/docs/padroes/po-ui-quirks-85","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#1-po-page-content-blank-on-load-opacity-timing--updated","content":"**Symptom:** Page renders the title/header but ALL content below it is invisible on first\nload (filter bar, tables, buttons — everything inside `ng-content`)."},"1910":{"id":"/docs/padroes/po-ui-quirks-86","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#1-po-page-content-blank-on-load-opacity-timing--updated","content":"**Root cause (confirmed by PO-UI source):**\n`PoPageContentComponent` sets `contentOpacity = 0` on creation and calls\n`recalculateHeaderSize()` in `ngAfterViewInit`, which uses `setTimeout` to set\n`contentOpacity = 1`. In **OnPush** components without an async data load (e.g., using\nsynchronous demo data), the component is already \"clean\" when that `setTimeout` fires —\nAngular skips the entire subtree during CD and `contentOpacity = 1` is never reflected\nin the DOM. Components that make HTTP requests are \"accidentally\" safe because the HTTP\nresponse triggers a `markForCheck()` after the `setTimeout` has already run."},"1911":{"id":"/docs/padroes/po-ui-quirks-87","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#1-po-page-content-blank-on-load-opacity-timing--updated","content":"**Affects:** Every OnPush component that uses `po-page-default`, `po-page-list`,\n`po-page-edit`, or `po-page-detail` AND loads data synchronously (demo constants, signals\ninitialized at declaration, etc.)."},"1912":{"id":"/docs/padroes/po-ui-quirks-88","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#1-po-page-content-blank-on-load-opacity-timing--updated","content":"**Fix — mandatory for every OnPush component using `po-page-*`:**"},"1913":{"id":"/docs/padroes/po-ui-quirks-89","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#1-po-page-content-blank-on-load-opacity-timing--updated","content":"**Alternative (when HTTP is used):** the HTTP response auto-triggers `markForCheck()` via\nsignal update, so no explicit `ngAfterViewInit` is needed. But adding it anyway is safe\nand makes the component resilient to future refactors."},"1914":{"id":"/docs/padroes/po-ui-quirks-90","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#2-po-input-bottom-padding-misaligns-buttons-8px-offset","content":"**Symptom:** Buttons placed in the same flex row as `po-input` fields appear 8px lower\nthan the visible input field edge, even with `align-items: flex-end` on the container."},"1915":{"id":"/docs/padroes/po-ui-quirks-91","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#2-po-input-bottom-padding-misaligns-buttons-8px-offset","content":"**Root cause:** `po-input` renders a wrapper that includes an invisible 8px space below\nthe visible input field, reserved for validation error messages. `flex-end` aligns to the\nbottom of this wrapper (including the invisible 8px), not to the bottom of the visible field."},"1916":{"id":"/docs/padroes/po-ui-quirks-92","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#2-po-input-bottom-padding-misaligns-buttons-8px-offset","content":"**Fix:** Add `margin-bottom: 8px` to the button element or its container to push it up\nby the same 8px, aligning it with the visible input bottom edge."},"1917":{"id":"/docs/padroes/po-ui-quirks-93","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#2-po-input-bottom-padding-misaligns-buttons-8px-offset","content":"**Measurement verification (Playwright):**"},"1918":{"id":"/docs/padroes/po-ui-quirks-94","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"**Symptom:** When two `po-table` components are placed side by side (flex:1 each),\neach table generates a horizontal scrollbar even though the specified `p-width` values\nseem reasonable."},"1919":{"id":"/docs/padroes/po-ui-quirks-95","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"**Root cause:** po-table adds an internal selectable-column (`po-table-column-selectable`)\nof **56px** that is NOT represented in `PoTableColumn[]`. This hidden 56px is added on\ntop of the sum of all `p-width` values, pushing the table wider than its container."},"1920":{"id":"/docs/padroes/po-ui-quirks-96","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"**Fix (two steps):**"},"1921":{"id":"/docs/padroes/po-ui-quirks-97","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"**Step 1 — Reduce the internal checkbox column via `::ng-deep`:**"},"1922":{"id":"/docs/padroes/po-ui-quirks-98","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"**Step 2 — Calculate `p-width` values so that their sum + checkbox = panel width:**"},"1923":{"id":"/docs/padroes/po-ui-quirks-99","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"**Step 3 — Use gap: 4px (not 8px) between panels** to maximize panel width:"},"1924":{"id":"/docs/padroes/po-ui-quirks-100","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"**Column width reference at 11px font (8px cell padding per side):**"},"1925":{"id":"/docs/padroes/po-ui-quirks-101","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"Content"},"1926":{"id":"/docs/padroes/po-ui-quirks-102","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"Example"},"1927":{"id":"/docs/padroes/po-ui-quirks-103","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"Minimum width"},"1928":{"id":"/docs/padroes/po-ui-quirks-104","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"Date"},"1929":{"id":"/docs/padroes/po-ui-quirks-105","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"\"10/01/2025\""},"1930":{"id":"/docs/padroes/po-ui-quirks-106","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"84px"},"1931":{"id":"/docs/padroes/po-ui-quirks-107","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"Currency"},"1932":{"id":"/docs/padroes/po-ui-quirks-108","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"\"3.200,00\""},"1933":{"id":"/docs/padroes/po-ui-quirks-109","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"68px"},"1934":{"id":"/docs/padroes/po-ui-quirks-110","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"Short code 5 chars"},"1935":{"id":"/docs/padroes/po-ui-quirks-111","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"\"NF001\""},"1936":{"id":"/docs/padroes/po-ui-quirks-112","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"50px"},"1937":{"id":"/docs/padroes/po-ui-quirks-113","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"Medium code 6 chars"},"1938":{"id":"/docs/padroes/po-ui-quirks-114","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"\"PED001\""},"1939":{"id":"/docs/padroes/po-ui-quirks-115","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"58px"},"1940":{"id":"/docs/padroes/po-ui-quirks-116","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"Status dot"},"1941":{"id":"/docs/padroes/po-ui-quirks-117","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"●"},"1942":{"id":"/docs/padroes/po-ui-quirks-118","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"28px"},"1943":{"id":"/docs/padroes/po-ui-quirks-119","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"3-digit number"},"1944":{"id":"/docs/padroes/po-ui-quirks-120","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"\"001\""},"1945":{"id":"/docs/padroes/po-ui-quirks-121","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"36px"},"1946":{"id":"/docs/padroes/po-ui-quirks-122","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#4-po-table-p-maxlength-binding-name","content":"**Symptom:** Angular compilation error: `NG8002: Can't bind to 'p-max-length' since it isn't a known property of 'po-input'`."},"1947":{"id":"/docs/padroes/po-ui-quirks-123","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#4-po-table-p-maxlength-binding-name","content":"**Root cause:** The correct Angular input alias is `p-maxlength` (no hyphen between `max` and `length`)."},"1948":{"id":"/docs/padroes/po-ui-quirks-124","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#5-dynamic-table-height-no-page-scroll","content":"**Pattern:** Use a `computed` signal that reacts to window resize to keep the `po-table`\nheight filling the viewport without a page-level scrollbar."},"1949":{"id":"/docs/padroes/po-ui-quirks-125","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#5-dynamic-table-height-no-page-scroll","content":"**For two-panel browses with a conditional contextual bar:**"},"1950":{"id":"/docs/padroes/po-ui-quirks-126","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#5-dynamic-table-height-no-page-scroll","content":"**Calibration:** After implementing, verify with Playwright:"},"1951":{"id":"/docs/padroes/po-ui-quirks-127","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#6-po-table-selection-no-p-selected-rows-output","content":"**Symptom:** No TypeScript error but the selection never fires / rows never accumulate."},"1952":{"id":"/docs/padroes/po-ui-quirks-128","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#6-po-table-selection-no-p-selected-rows-output","content":"**Root cause:** `p-selected-rows` is not an output of `po-table`. The correct outputs for\nrow selection are individual-row events, not a batch-selection array."},"1953":{"id":"/docs/padroes/po-ui-quirks-129","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#7-po-table-frozen-columns-and-p-selectable-entire-line","content":"When `[p-selectable]=\"true\"` is used, po-table adds a checkbox column that makes every\ncolumn frozen (`po-frozen-column` class on all `<th>` elements). This is expected behavior."},"1954":{"id":"/docs/padroes/po-ui-quirks-130","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#7-po-table-frozen-columns-and-p-selectable-entire-line","content":"To restrict selection to the checkbox only (not clicking anywhere on the row):"},"1955":{"id":"/docs/padroes/po-ui-quirks-131","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#7-po-table-frozen-columns-and-p-selectable-entire-line","content":"This is essential for two-panel browse screens where accidental row selection\nwhile reading data would be disruptive."},"1956":{"id":"/docs/padroes/po-ui-quirks-132","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#8-po-table-programmatic-selected-false-does-not-cancel-a-just-committed-selection","content":"**Symptom:** When `(p-selected)` fires and you want to reject the selection (e.g., guard\nvalidation failed), setting `$selected: false` on the item synchronously has no effect.\nThe row stays visually selected, and clicking it again fires `(p-selected)` instead of\n`(p-unselected)`, so the warning message fires a second time."},"1957":{"id":"/docs/padroes/po-ui-quirks-133","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#8-po-table-programmatic-selected-false-does-not-cancel-a-just-committed-selection","content":"**Root cause:** po-table adds the row to its internal `selectedRows` array **before**\ndispatching the `(p-selected)` event. Any synchronous `$selected: false` change on the\nitems signal is processed in the same change-detection cycle — but po-table's internal\nstate already has the row, so the visual state stays selected even though the data says\n`$selected: false`. This desync causes a second `(p-selected)` on the next click instead\nof `(p-unselected)`."},"1958":{"id":"/docs/padroes/po-ui-quirks-134","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#8-po-table-programmatic-selected-false-does-not-cancel-a-just-committed-selection","content":"**Fix:** Defer the items array replacement to `setTimeout(0)`. This lets the current\nevent cycle complete, then replaces the items array in the next microtask. po-table's\n`ngOnChanges` receives the new array and reinitializes its selection from `$selected`,\ncorrectly showing the row as unselected."},"1959":{"id":"/docs/padroes/po-ui-quirks-135","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#8-po-table-programmatic-selected-false-does-not-cancel-a-just-committed-selection","content":"**Note:** The `setTimeout(0)` causes a \\~1-frame visual flash where the row appears\nselected before reverting. This is imperceptible in practice but unavoidable with the\ncurrent PO-UI `(p-selected)` API."},"1960":{"id":"/docs/padroes/po-ui-quirks-136","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#9-po-table-keyboard-row-navigation-arrowup--arrowdown","content":"**Context:** po-table has no built-in keyboard navigation. Protheus users expect arrow-key\nnavigation between rows (like the native Protheus grid). When a browse acts as a master\nthat loads detail data on row change, this is especially important."},"1961":{"id":"/docs/padroes/po-ui-quirks-137","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#9-po-table-keyboard-row-navigation-arrowup--arrowdown","content":"**Pattern — three-part implementation:**"},"1962":{"id":"/docs/padroes/po-ui-quirks-138","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#part-3--dom-highlight--scroll-manual-because-css-focus-does-not-reach-table-rows","content":"> **⚠️ Never use `row.scrollIntoView(\\{ block: 'nearest' \\})`** — it does not account for the\n> sticky `thead`. When navigating to row 0 (or any row near the top), the row becomes hidden\n> behind the fixed header. Use the manual scroll calculation below instead."},"1963":{"id":"/docs/padroes/po-ui-quirks-139","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#part-5--wiring-click--init","content":"**Important notes:**"},"1964":{"id":"/docs/padroes/po-ui-quirks-140","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#part-5--wiring-click--init","content":"Use `setTimeout(..., 50)` — NOT `0ms`. At 0ms, PO-UI's change detection has not completed and `getBoundingClientRect()` returns stale values. 50ms matches the pattern used in production Divergências screens."},"1965":{"id":"/docs/padroes/po-ui-quirks-141","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#part-5--wiring-click--init","content":"The `input/textarea` guard prevents arrow keys from triggering navigation while the user types in filter fields."},"1966":{"id":"/docs/padroes/po-ui-quirks-142","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#part-5--wiring-click--init","content":"Works for standard `po-table` (all rows are `<tr>` inside a single `<tbody>`). For tables with `p-detail` (expandable rows), each item renders as its own `<tbody>` — use `querySelectorAll(':scope > tbody')` on the `<table>` element instead."},"1967":{"id":"/docs/padroes/po-ui-quirks-143","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#part-5--wiring-click--init","content":"To hide PO-UI's checkbox column when using `p-selectable` purely for click events:"},"1968":{"id":"/docs/padroes/po-ui-quirks-144","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#10-dual-browse-keyboard-navigation-master--detail","content":"When a screen has **two stacked po-table components** where the top one (master) drives the bottom one (detail), both need independent keyboard navigation. Use `activeBrowse` to route arrow keys, **Tab** to switch between browses."},"1969":{"id":"/docs/padroes/po-ui-quirks-145","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#hint-in-the-browse-header","content":"Show a hint so the user knows how to switch and navigate:"},"1970":{"id":"/docs/padroes/po-ui-quirks-146","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#11-potabledetail--width-property-not-supported-ts2353","content":"**Symptom:** TypeScript compiler throws `TS2353: Object literal may only specify known properties, and 'width' does not exist in type 'PoTableDetailColumn'` when defining columns inside `buildDetailConfig()`."},"1971":{"id":"/docs/padroes/po-ui-quirks-147","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#11-potabledetail--width-property-not-supported-ts2353","content":"**Root cause:** `PoTableDetail.columns` uses the internal type `PoTableDetailColumn`, which is a subset of `PoTableColumn` and does **not** include `width`. The `width` property is only valid on master columns (`PoTableColumn[]`), not on detail columns."},"1972":{"id":"/docs/padroes/po-ui-quirks-148","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#11-potabledetail--width-property-not-supported-ts2353","content":"**Fix:** Remove all `width` properties from detail columns. Only `property`, `label`, `type`, and `format` are supported."},"1973":{"id":"/docs/padroes/po-ui-quirks-149","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"**Symptom:** `po-table` renders correctly in the DOM but is invisible when the page is first\nnavigated to. It only becomes visible after the user moves the mouse or triggers any event.\nThe bug is most noticeable when the table is inside an `@if` block."},"1974":{"id":"/docs/padroes/po-ui-quirks-150","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"**Root cause (verified against PO-UI source):**"},"1975":{"id":"/docs/padroes/po-ui-quirks-151","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"`po-table` initialises `tableOpacity = 0`. There are two paths to `setTableOpacity(1)`:"},"1976":{"id":"/docs/padroes/po-ui-quirks-152","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"Path"},"1977":{"id":"/docs/padroes/po-ui-quirks-153","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"Triggered by"},"1978":{"id":"/docs/padroes/po-ui-quirks-154","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"Timing"},"1979":{"id":"/docs/padroes/po-ui-quirks-155","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"`verifyCalculateHeightTableContainer()` → `calculateHeightTableContainer()` → `setTableOpacity(1)`"},"1980":{"id":"/docs/padroes/po-ui-quirks-156","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"`[p-height]` is set"},"1981":{"id":"/docs/padroes/po-ui-quirks-157","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"**Synchronous** — runs inside `ngDoCheck`, same CD cycle"},"1982":{"id":"/docs/padroes/po-ui-quirks-158","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"`debounceResize()` → `setTimeout(() => setTableOpacity(1))`"},"1983":{"id":"/docs/padroes/po-ui-quirks-159","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"`offsetWidth > 0` detected in `ngDoCheck` without `[p-height]`"},"1984":{"id":"/docs/padroes/po-ui-quirks-160","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"**Asynchronous** — `setTimeout` fires after current CD cycle"},"1985":{"id":"/docs/padroes/po-ui-quirks-161","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"With `ChangeDetectionStrategy.OnPush`, the host component is already marked \"clean\" after the\nfirst CD cycle. When the async `setTimeout` fires and calls `setTableOpacity(1)`, Angular does\nnot re-check the OnPush component, so the table stays invisible until a future event (mouse\nmove, click) triggers the next CD cycle."},"1986":{"id":"/docs/padroes/po-ui-quirks-162","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"**Fix: always set `[p-height]` on every `po-table` in OnPush components.**"},"1987":{"id":"/docs/padroes/po-ui-quirks-163","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"For dynamic height (fills viewport), use a `computed` signal (see Quirk 5):"},"1988":{"id":"/docs/padroes/po-ui-quirks-164","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"**Rule:** Every `po-table` generated in a `ChangeDetectionStrategy.OnPush` component MUST\nhave `[p-height]` set. No exceptions. A table inside an `@if` block is especially vulnerable."},"1989":{"id":"/docs/padroes/po-ui-quirks-165","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"**Symptom:** Binding `(p-value-change)=\"myHandler($event)\"` on `po-dynamic-form` compiles\nwithout errors but the handler is never called, regardless of what the user types."},"1990":{"id":"/docs/padroes/po-ui-quirks-166","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"**Root cause (verified against PO-UI source):**"},"1991":{"id":"/docs/padroes/po-ui-quirks-167","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"`PoDynamicFormBaseComponent` declares only one `@Output`:"},"1992":{"id":"/docs/padroes/po-ui-quirks-168","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"There is no `p-value-change` output. Angular silently ignores unknown event bindings on\ncustom elements, so there is no compilation error and no runtime warning — the handler\nsimply never fires."},"1993":{"id":"/docs/padroes/po-ui-quirks-169","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"**Fix: use `(p-form)` to receive the `NgForm` instance, then subscribe to `form.valueChanges`.**"},"1994":{"id":"/docs/padroes/po-ui-quirks-170","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"**Notes:**"},"1995":{"id":"/docs/padroes/po-ui-quirks-171","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"`form.valueChanges` fires on **every keystroke** for `po-decimal` / `po-number` fields\n(via `ControlValueAccessor.onChange` in `onInput`), and on **blur** for text fields."},"1996":{"id":"/docs/padroes/po-ui-quirks-172","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"`[(p-value)]` two-way binding silently fails for the same reason — there is no\n`p-value-change` output for Angular to wire the write-back. Use `[p-value]` (one-way)\nfor initialisation and update `headerValues` manually inside `onFormInit`."},"1997":{"id":"/docs/padroes/po-ui-quirks-173","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"The `NgForm` instance is emitted inside a `setTimeout` in PO-UI's source, so `onFormInit`\nwill always be called asynchronously, after the first CD cycle completes."},"1998":{"id":"/docs/padroes/protheus-rest","page_id":"/docs/padroes/protheus-rest","type":"page","content":"Protheus REST Integration Patterns","breadcrumbs":["Documentação","Padrões","Padrões"],"tags":[],"url":"/docs/padroes/protheus-rest"},"1999":{"id":"/docs/padroes/protheus-rest-0","page_id":"/docs/padroes/protheus-rest","tags":[],"type":"text","url":"/docs/padroes/protheus-rest","content":"typescript"},"2000":{"id":"/docs/padroes/protheus-rest-1","page_id":"/docs/padroes/protheus-rest","type":"heading","tags":[],"url":"/docs/padroes/protheus-rest#protheus-rest-integration-patterns","content":"Protheus REST Integration Patterns"},"2001":{"id":"/docs/padroes/protheus-rest-2","page_id":"/docs/padroes/protheus-rest","type":"heading","tags":[],"url":"/docs/padroes/protheus-rest#standard-response-contract","content":"Standard Response Contract"},"2002":{"id":"/docs/padroes/protheus-rest-3","page_id":"/docs/padroes/protheus-rest","type":"heading","tags":[],"url":"/docs/padroes/protheus-rest#standard-query-parameters","content":"Standard Query Parameters"},"2003":{"id":"/docs/padroes/protheus-rest-4","page_id":"/docs/padroes/protheus-rest","type":"heading","tags":[],"url":"/docs/padroes/protheus-rest#generic-service-pattern","content":"Generic Service Pattern"},"2004":{"id":"/docs/padroes/protheus-rest-5","page_id":"/docs/padroes/protheus-rest","type":"heading","tags":[],"url":"/docs/padroes/protheus-rest#composite-key-pattern-código--loja","content":"Composite Key Pattern (código + loja)"},"2005":{"id":"/docs/padroes/protheus-rest-6","page_id":"/docs/padroes/protheus-rest","type":"heading","tags":[],"url":"/docs/padroes/protheus-rest#protheus-error-handling","content":"Protheus Error Handling"},"2006":{"id":"/docs/padroes/protheus-rest-7","page_id":"/docs/padroes/protheus-rest","type":"heading","tags":[],"url":"/docs/padroes/protheus-rest#http-status-code-handling","content":"HTTP Status Code Handling"},"2007":{"id":"/docs/padroes/protheus-rest-8","page_id":"/docs/padroes/protheus-rest","type":"heading","tags":[],"url":"/docs/padroes/protheus-rest#proxy-configuration-proxyconfjson","content":"Proxy Configuration (proxy.conf.json)"},"2008":{"id":"/docs/padroes/protheus-rest-9","page_id":"/docs/padroes/protheus-rest","type":"heading","tags":[],"url":"/docs/padroes/protheus-rest#environment-based-base-url","content":"Environment-Based Base URL"},"2009":{"id":"/docs/padroes/protheus-rest-10","page_id":"/docs/padroes/protheus-rest","tags":[],"type":"text","url":"/docs/padroes/protheus-rest#standard-query-parameters","content":"Parameter"},"2010":{"