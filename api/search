droes/po-ui-quirks-115","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"58px"},"2183":{"id":"/docs/padroes/po-ui-quirks-116","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"Status dot"},"2184":{"id":"/docs/padroes/po-ui-quirks-117","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"●"},"2185":{"id":"/docs/padroes/po-ui-quirks-118","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"28px"},"2186":{"id":"/docs/padroes/po-ui-quirks-119","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"3-digit number"},"2187":{"id":"/docs/padroes/po-ui-quirks-120","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"\"001\""},"2188":{"id":"/docs/padroes/po-ui-quirks-121","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#3-po-table-horizontal-scroll-in-side-by-side-panels","content":"36px"},"2189":{"id":"/docs/padroes/po-ui-quirks-122","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#4-po-table-p-maxlength-binding-name","content":"**Symptom:** Angular compilation error: `NG8002: Can't bind to 'p-max-length' since it isn't a known property of 'po-input'`."},"2190":{"id":"/docs/padroes/po-ui-quirks-123","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#4-po-table-p-maxlength-binding-name","content":"**Root cause:** The correct Angular input alias is `p-maxlength` (no hyphen between `max` and `length`)."},"2191":{"id":"/docs/padroes/po-ui-quirks-124","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#5-dynamic-table-height-no-page-scroll","content":"**Pattern:** Use a `computed` signal that reacts to window resize to keep the `po-table`\nheight filling the viewport without a page-level scrollbar."},"2192":{"id":"/docs/padroes/po-ui-quirks-125","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#5-dynamic-table-height-no-page-scroll","content":"**For two-panel browses with a conditional contextual bar:**"},"2193":{"id":"/docs/padroes/po-ui-quirks-126","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#5-dynamic-table-height-no-page-scroll","content":"**Calibration:** After implementing, verify with Playwright:"},"2194":{"id":"/docs/padroes/po-ui-quirks-127","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#6-po-table-selection-no-p-selected-rows-output","content":"**Symptom:** No TypeScript error but the selection never fires / rows never accumulate."},"2195":{"id":"/docs/padroes/po-ui-quirks-128","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#6-po-table-selection-no-p-selected-rows-output","content":"**Root cause:** `p-selected-rows` is not an output of `po-table`. The correct outputs for\nrow selection are individual-row events, not a batch-selection array."},"2196":{"id":"/docs/padroes/po-ui-quirks-129","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#7-po-table-frozen-columns-and-p-selectable-entire-line","content":"When `[p-selectable]=\"true\"` is used, po-table adds a checkbox column that makes every\ncolumn frozen (`po-frozen-column` class on all `<th>` elements). This is expected behavior."},"2197":{"id":"/docs/padroes/po-ui-quirks-130","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#7-po-table-frozen-columns-and-p-selectable-entire-line","content":"To restrict selection to the checkbox only (not clicking anywhere on the row):"},"2198":{"id":"/docs/padroes/po-ui-quirks-131","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#7-po-table-frozen-columns-and-p-selectable-entire-line","content":"This is essential for two-panel browse screens where accidental row selection\nwhile reading data would be disruptive."},"2199":{"id":"/docs/padroes/po-ui-quirks-132","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#8-po-table-programmatic-selected-false-does-not-cancel-a-just-committed-selection","content":"**Symptom:** When `(p-selected)` fires and you want to reject the selection (e.g., guard\nvalidation failed), setting `$selected: false` on the item synchronously has no effect.\nThe row stays visually selected, and clicking it again fires `(p-selected)` instead of\n`(p-unselected)`, so the warning message fires a second time."},"2200":{"id":"/docs/padroes/po-ui-quirks-133","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#8-po-table-programmatic-selected-false-does-not-cancel-a-just-committed-selection","content":"**Root cause:** po-table adds the row to its internal `selectedRows` array **before**\ndispatching the `(p-selected)` event. Any synchronous `$selected: false` change on the\nitems signal is processed in the same change-detection cycle — but po-table's internal\nstate already has the row, so the visual state stays selected even though the data says\n`$selected: false`. This desync causes a second `(p-selected)` on the next click instead\nof `(p-unselected)`."},"2201":{"id":"/docs/padroes/po-ui-quirks-134","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#8-po-table-programmatic-selected-false-does-not-cancel-a-just-committed-selection","content":"**Fix:** Defer the items array replacement to `setTimeout(0)`. This lets the current\nevent cycle complete, then replaces the items array in the next microtask. po-table's\n`ngOnChanges` receives the new array and reinitializes its selection from `$selected`,\ncorrectly showing the row as unselected."},"2202":{"id":"/docs/padroes/po-ui-quirks-135","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#8-po-table-programmatic-selected-false-does-not-cancel-a-just-committed-selection","content":"**Note:** The `setTimeout(0)` causes a \\~1-frame visual flash where the row appears\nselected before reverting. This is imperceptible in practice but unavoidable with the\ncurrent PO-UI `(p-selected)` API."},"2203":{"id":"/docs/padroes/po-ui-quirks-136","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#9-po-table-keyboard-row-navigation-arrowup--arrowdown","content":"**Context:** po-table has no built-in keyboard navigation. Protheus users expect arrow-key\nnavigation between rows (like the native Protheus grid). When a browse acts as a master\nthat loads detail data on row change, this is especially important."},"2204":{"id":"/docs/padroes/po-ui-quirks-137","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#9-po-table-keyboard-row-navigation-arrowup--arrowdown","content":"**Pattern — three-part implementation:**"},"2205":{"id":"/docs/padroes/po-ui-quirks-138","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#part-3--dom-highlight--scroll-manual-because-css-focus-does-not-reach-table-rows","content":"> **⚠️ Never use `row.scrollIntoView(\\{ block: 'nearest' \\})`** — it does not account for the\n> sticky `thead`. When navigating to row 0 (or any row near the top), the row becomes hidden\n> behind the fixed header. Use the manual scroll calculation below instead."},"2206":{"id":"/docs/padroes/po-ui-quirks-139","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#part-5--wiring-click--init","content":"**Important notes:**"},"2207":{"id":"/docs/padroes/po-ui-quirks-140","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#part-5--wiring-click--init","content":"Use `setTimeout(..., 50)` — NOT `0ms`. At 0ms, PO-UI's change detection has not completed and `getBoundingClientRect()` returns stale values. 50ms matches the pattern used in production Divergências screens."},"2208":{"id":"/docs/padroes/po-ui-quirks-141","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#part-5--wiring-click--init","content":"The `input/textarea` guard prevents arrow keys from triggering navigation while the user types in filter fields."},"2209":{"id":"/docs/padroes/po-ui-quirks-142","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#part-5--wiring-click--init","content":"Works for standard `po-table` (all rows are `<tr>` inside a single `<tbody>`). For tables with `p-detail` (expandable rows), each item renders as its own `<tbody>` — use `querySelectorAll(':scope > tbody')` on the `<table>` element instead."},"2210":{"id":"/docs/padroes/po-ui-quirks-143","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#part-5--wiring-click--init","content":"To hide PO-UI's checkbox column when using `p-selectable` purely for click events:"},"2211":{"id":"/docs/padroes/po-ui-quirks-144","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#10-dual-browse-keyboard-navigation-master--detail","content":"When a screen has **two stacked po-table components** where the top one (master) drives the bottom one (detail), both need independent keyboard navigation. Use `activeBrowse` to route arrow keys, **Tab** to switch between browses."},"2212":{"id":"/docs/padroes/po-ui-quirks-145","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#hint-in-the-browse-header","content":"Show a hint so the user knows how to switch and navigate:"},"2213":{"id":"/docs/padroes/po-ui-quirks-146","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#11-potabledetail--width-property-not-supported-ts2353","content":"**Symptom:** TypeScript compiler throws `TS2353: Object literal may only specify known properties, and 'width' does not exist in type 'PoTableDetailColumn'` when defining columns inside `buildDetailConfig()`."},"2214":{"id":"/docs/padroes/po-ui-quirks-147","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#11-potabledetail--width-property-not-supported-ts2353","content":"**Root cause:** `PoTableDetail.columns` uses the internal type `PoTableDetailColumn`, which is a subset of `PoTableColumn` and does **not** include `width`. The `width` property is only valid on master columns (`PoTableColumn[]`), not on detail columns."},"2215":{"id":"/docs/padroes/po-ui-quirks-148","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#11-potabledetail--width-property-not-supported-ts2353","content":"**Fix:** Remove all `width` properties from detail columns. Only `property`, `label`, `type`, and `format` are supported."},"2216":{"id":"/docs/padroes/po-ui-quirks-149","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"**Symptom:** `po-table` renders correctly in the DOM but is invisible when the page is first\nnavigated to. It only becomes visible after the user moves the mouse or triggers any event.\nThe bug is most noticeable when the table is inside an `@if` block."},"2217":{"id":"/docs/padroes/po-ui-quirks-150","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"**Root cause (verified against PO-UI source):**"},"2218":{"id":"/docs/padroes/po-ui-quirks-151","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"`po-table` initialises `tableOpacity = 0`. There are two paths to `setTableOpacity(1)`:"},"2219":{"id":"/docs/padroes/po-ui-quirks-152","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"Path"},"2220":{"id":"/docs/padroes/po-ui-quirks-153","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"Triggered by"},"2221":{"id":"/docs/padroes/po-ui-quirks-154","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"Timing"},"2222":{"id":"/docs/padroes/po-ui-quirks-155","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"`verifyCalculateHeightTableContainer()` → `calculateHeightTableContainer()` → `setTableOpacity(1)`"},"2223":{"id":"/docs/padroes/po-ui-quirks-156","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"`[p-height]` is set"},"2224":{"id":"/docs/padroes/po-ui-quirks-157","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"**Synchronous** — runs inside `ngDoCheck`, same CD cycle"},"2225":{"id":"/docs/padroes/po-ui-quirks-158","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"`debounceResize()` → `setTimeout(() => setTableOpacity(1))`"},"2226":{"id":"/docs/padroes/po-ui-quirks-159","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"`offsetWidth > 0` detected in `ngDoCheck` without `[p-height]`"},"2227":{"id":"/docs/padroes/po-ui-quirks-160","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"**Asynchronous** — `setTimeout` fires after current CD cycle"},"2228":{"id":"/docs/padroes/po-ui-quirks-161","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"With `ChangeDetectionStrategy.OnPush`, the host component is already marked \"clean\" after the\nfirst CD cycle. When the async `setTimeout` fires and calls `setTableOpacity(1)`, Angular does\nnot re-check the OnPush component, so the table stays invisible until a future event (mouse\nmove, click) triggers the next CD cycle."},"2229":{"id":"/docs/padroes/po-ui-quirks-162","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"**Fix: always set `[p-height]` on every `po-table` in OnPush components.**"},"2230":{"id":"/docs/padroes/po-ui-quirks-163","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"For dynamic height (fills viewport), use a `computed` signal (see Quirk 5):"},"2231":{"id":"/docs/padroes/po-ui-quirks-164","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#12-po-table-invisible-on-first-load-in-onpush-components-mandatory-p-height","content":"**Rule:** Every `po-table` generated in a `ChangeDetectionStrategy.OnPush` component MUST\nhave `[p-height]` set. No exceptions. A table inside an `@if` block is especially vulnerable."},"2232":{"id":"/docs/padroes/po-ui-quirks-165","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"**Symptom:** Binding `(p-value-change)=\"myHandler($event)\"` on `po-dynamic-form` compiles\nwithout errors but the handler is never called, regardless of what the user types."},"2233":{"id":"/docs/padroes/po-ui-quirks-166","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"**Root cause (verified against PO-UI source):**"},"2234":{"id":"/docs/padroes/po-ui-quirks-167","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"`PoDynamicFormBaseComponent` declares only one `@Output`:"},"2235":{"id":"/docs/padroes/po-ui-quirks-168","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"There is no `p-value-change` output. Angular silently ignores unknown event bindings on\ncustom elements, so there is no compilation error and no runtime warning — the handler\nsimply never fires."},"2236":{"id":"/docs/padroes/po-ui-quirks-169","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"**Fix: use `(p-form)` to receive the `NgForm` instance, then subscribe to `form.valueChanges`.**"},"2237":{"id":"/docs/padroes/po-ui-quirks-170","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"**Notes:**"},"2238":{"id":"/docs/padroes/po-ui-quirks-171","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"`form.valueChanges` fires on **every keystroke** for `po-decimal` / `po-number` fields\n(via `ControlValueAccessor.onChange` in `onInput`), and on **blur** for text fields."},"2239":{"id":"/docs/padroes/po-ui-quirks-172","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"`[(p-value)]` two-way binding silently fails for the same reason — there is no\n`p-value-change` output for Angular to wire the write-back. Use `[p-value]` (one-way)\nfor initialisation and update `headerValues` manually inside `onFormInit`."},"2240":{"id":"/docs/padroes/po-ui-quirks-173","page_id":"/docs/padroes/po-ui-quirks","tags":[],"type":"text","url":"/docs/padroes/po-ui-quirks#13-po-dynamic-form-p-value-change-does-not-exist","content":"The `NgForm` instance is emitted inside a `setTimeout` in PO-UI's source, so `onFormInit`\nwill always be called asynchronously, after the first CD cycle completes."},"2241":{"id":"/docs/padroes/protheus-rest","page_id":"/docs/padroes/protheus-rest","type":"page","content":"Protheus REST Integration Patterns","breadcrumbs":["Documentação","Padrões","Padrões"],"tags":[],"url":"/doc